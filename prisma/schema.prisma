// Bourbon & Oak — e-commerce schema
// Neon Postgres + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Availability {
  IN_STOCK
  LOW_STOCK
  ALLOCATED
  PRE_ORDER
  SOLD_OUT
  ARCHIVED
}

enum ProductionStyle {
  SINGLE_BARREL
  SMALL_BATCH
  BOTTLED_IN_BOND
  BARREL_PROOF
  STANDARD
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  // Hero image for the category landing
  imageUrl    String?
  // Ordering on the shop sidebar
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  subtitle    String?
  description String   @db.Text
  story       String?  @db.Text

  // Pricing — single bottle, optional case-of-N (null = bottle-only allocation)
  bottlePrice    Decimal  @db.Decimal(10, 2)
  casePrice      Decimal? @db.Decimal(10, 2)
  bottlesPerCase Int?
  compareAtPrice Decimal? @db.Decimal(10, 2)

  // Whiskey specs
  ageYears        Int?
  isNAS           Boolean @default(false)
  proof           Decimal @db.Decimal(5, 2)
  abv             Decimal @db.Decimal(5, 2)
  bottleSizeMl    Int     @default(750)

  // Mash bill (percentages — should sum to ~100)
  cornPercent     Int?
  ryePercent      Int?
  wheatPercent    Int?
  maltedBarleyPct Int?

  // Provenance
  distillery     String
  region         String
  state          String?
  masterDistiller String?
  caskType       String?  // e.g. "New American White Oak"
  charLevel      Int?     // 1-4
  finishCask     String?  // e.g. "Sherry", "Port" — null if none
  batchNumber    String?
  barrelNumber   String?
  releaseYear    Int?

  // Production flags
  productionStyle ProductionStyle @default(STANDARD)
  isChillFiltered Boolean         @default(true)
  isLimitedEdition Boolean        @default(false)
  isAllocated      Boolean        @default(false)
  totalBottlesProduced Int?

  // Tasting profile
  nose            String?  @db.Text
  palate          String?  @db.Text
  finish          String?  @db.Text
  flavorTags      String[] @default([])
  servingSuggestion String?
  foodPairings    String?  @db.Text
  videoUrl        String?

  // Commerce
  sku           String       @unique
  stockBottles  Int          @default(0)
  stockCases    Int          @default(0)
  availability  Availability @default(IN_STOCK)
  rating        Decimal?     @db.Decimal(2, 1)
  reviewCount   Int          @default(0)
  isFeatured    Boolean      @default(false)
  badge         String?      // e.g. "Best Seller", "New Arrival"

  categoryId String
  category   Category       @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  awards     Award[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([availability])
  @@index([isFeatured])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Award {
  id           String  @id @default(cuid())
  name         String
  organization String?
  year         Int?
  medal        String? // "Gold", "Double Gold", "Silver"

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CARD
  PAYPAL
  CHIME
  APPLE_PAY
  CRYPTO
}

enum ShippingMethod {
  STANDARD
  EXPRESS
  OVERNIGHT
  WHITE_GLOVE
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  status      OrderStatus @default(PENDING)

  // Contact
  email String
  phone String

  // Shipping address
  fullName     String
  addressLine1 String
  addressLine2 String?
  city         String
  region       String
  postal       String
  country      String

  // Methods
  shippingMethod ShippingMethod
  shippingCost   Decimal        @db.Decimal(10, 2)
  paymentMethod  PaymentMethod
  discountRate   Decimal        @db.Decimal(4, 3) @default(0)

  // Totals snapshot
  subtotal Decimal @db.Decimal(10, 2)
  discount Decimal @db.Decimal(10, 2) @default(0)
  tax      Decimal @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  notes String? @db.Text

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Snapshot at order time
  productId    String?
  productName  String
  productImage String
  ageLabel     String?
  unitPrice    Decimal @db.Decimal(10, 2)
  quantity     Int
  isCase       Boolean @default(false)

  @@index([orderId])
  @@index([productId])
}

enum SubscriberStatus {
  SUBSCRIBED
  UNSUBSCRIBED
}

model Subscriber {
  id        String           @id @default(cuid())
  email     String           @unique
  status    SubscriberStatus @default(SUBSCRIBED)
  source    String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum MessageStatus {
  UNREAD
  READ
  ARCHIVED
}

model ContactMessage {
  id      String        @id @default(cuid())
  name    String
  email   String
  subject String?
  body    String        @db.Text
  status  MessageStatus @default(UNREAD)

  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  userAgent String?  @db.Text
  // true = a logged-in admin device that should receive live-chat pings.
  // false = a storefront visitor who opted into product announcements.
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([isAdmin])
}

enum ChatSender {
  VISITOR
  ADMIN
}

enum ConversationStatus {
  OPEN
  CLOSED
}

model Conversation {
  id        String             @id @default(cuid())
  // The bol_vid visitor cookie value — ties the thread to a device.
  visitorId String
  status    ConversationStatus @default(OPEN)

  // Denormalized for fast inbox sorting + unread badges without scanning messages.
  lastMessageAt   DateTime @default(now())
  lastMessageFrom ChatSender @default(VISITOR)
  // Count of visitor messages the admin hasn't opened yet.
  adminUnread     Int      @default(0)
  // Last time we emailed the admin about this thread — throttles the email
  // fallback so rapid-fire messages don't flood the inbox.
  lastNotifiedAt  DateTime?

  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visitorId])
  @@index([status])
  @@index([lastMessageAt])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         ChatSender
  body           String       @db.Text
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

// Small key-value store for admin-editable config (e.g. the live-chat greeting).
model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model Visitor {
  // `id` is the visitor cookie value (UUID). Re-using the cookie keeps
  // someone "one unique" across visits even if their IP changes.
  id          String   @id
  country     String?
  countryCode String?  // ISO-3166-1 alpha-2
  region      String?
  city        String?
  userAgent   String?  @db.Text
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt

  visitDays VisitDay[]

  @@index([firstSeenAt])
  @@index([lastSeenAt])
  @@index([countryCode])
}

model VisitDay {
  id        String   @id @default(cuid())
  visitorId String
  visitor   Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  // `date` is normalized to UTC midnight so we get one row per visitor per day.
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([visitorId, date])
  @@index([date])
}
